{
  "buildCommand": "npm run build",
  "devCommand": "node -e 'console.log(\"Vercel API ready\"); setInterval(() => {}, 1000)'",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/|@vite/|@fs/|src/|node_modules/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
