{
  "buildCommand": "npm run build",
  "devCommand": "node -e 'require(\"http\").createServer().listen(process.env.PORT, () => console.log(\"Vercel API ready\"))'",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/|@vite/|@fs/|src/|node_modules/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
